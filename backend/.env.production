# Afarensis Enterprise - Production Environment Variables
# Copy to .env and fill in real values before deploying

# ── Environment ──
ENV=production
DEBUG=false

# ── Security (CHANGE THESE!) ──
SECRET_KEY=CHANGE-ME-TO-A-64-CHAR-RANDOM-STRING
ENCRYPTION_KEY=CHANGE-ME-TO-A-32-CHAR-RANDOM-STRING

# ── Database (PostgreSQL) ──
# Direct connection (development):
DATABASE_URL=postgresql+asyncpg://afarensis:afarensis_dev_2024@localhost:5432/afarensis
# Via PgBouncer (production):
# DATABASE_URL=postgresql+asyncpg://afarensis:YOUR_PASSWORD@localhost:6432/afarensis
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
AUTO_CREATE_TABLES=false

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── CORS (set to your actual domain) ──
ALLOWED_ORIGINS=["https://yourdomain.com"]
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ── API Keys (at least one LLM key recommended) ──
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── Email (for password resets) ──
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG...
# FROM_EMAIL=noreply@yourdomain.com

# ── Logging ──
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Feature Flags ──
FALLBACK_TO_MOCK_DATA=false
ENABLE_LLM_INTEGRATION=true
ENABLE_AUDIT_LOG=true
