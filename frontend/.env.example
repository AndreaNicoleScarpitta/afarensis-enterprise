# Afarensis Enterprise - Frontend Environment Variables
# Copy this file to .env.local for local development

# Backend API base URL. For local dev, point at your running backend.
# In production (served behind FastAPI) use the relative path /api/v1.
VITE_API_URL=http://localhost:8000/api/v1

# Environment label: development | staging | production
VITE_ENVIRONMENT=development
